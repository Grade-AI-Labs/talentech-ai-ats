# Azure OpenAI credentials for the LangChain.js client.
#
# The API selects `AzureOpenAIClient` only when ALL four of these are set
# (after trimming). Leave any of them unset to fall back to the
# deterministic `StubAIClient`, so `docker compose up` works on a fresh
# clone with zero configuration.
#
# The deployment named in AZURE_OPENAI_DEPLOYMENT_NAME should serve the
# `gpt-4.1-mini` model.

# Required: Azure OpenAI API key.
AZURE_OPENAI_API_KEY=

# Host. Provide ONE of these two:
#   - AZURE_OPENAI_ENDPOINT: full base URL, e.g. https://my-resource.openai.azure.com
#   - AZURE_OPENAI_API_INSTANCE_NAME: legacy instance form, e.g. "my-resource"
# AZURE_OPENAI_ENDPOINT takes precedence when both are set.
AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_INSTANCE_NAME=

# Required: name of the Azure OpenAI deployment serving gpt-4.1-mini.
AZURE_OPENAI_DEPLOYMENT_NAME=

# Required: Azure OpenAI API version, e.g. 2024-10-21.
AZURE_OPENAI_API_VERSION=
